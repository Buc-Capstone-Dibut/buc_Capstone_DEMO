DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
CORS_ORIGINS=http://localhost:3000

# LiveKit (STT/TTS pipeline — optional, leave blank to disable)
LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# OpenAI (STT/TTS real-time pipeline)
OPENAI_API_KEY=your_openai_api_key
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Voice VAD tuning
VOICE_VAD_THRESHOLD=0.015
VOICE_VAD_SILENCE_MS=700
VOICE_MIN_SPEECH_MS=350
VOICE_MAX_SEGMENT_MS=10000
