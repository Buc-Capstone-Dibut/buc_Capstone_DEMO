DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Gemini on Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=vertex-weare
GOOGLE_CLOUD_LOCATION=global
GEMINI_SERVICE_ACCOUNT_JSON_BASE64=your_vertex_service_account_json_base64
GEMINI_MODEL=gemini-2.5-flash

# Optional GitHub API token for public repo analysis stability
GITHUB_TOKEN=

CORS_ORIGINS=http://localhost:3000

# Voice pipeline
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# LiveKit (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# VAD tuning
VOICE_VAD_THRESHOLD=0.020
VOICE_VAD_SPEECH_START_MS=180
VOICE_VAD_SILENCE_MS=650
VOICE_MIN_SPEECH_MS=350
VOICE_VAD_MIN_UTTERANCE_MS=950
VOICE_VAD_SHORT_UTTERANCE_SILENCE_MS=1500
VOICE_TURN_END_GRACE_MS=320
VOICE_MAX_SEGMENT_MS=10000
