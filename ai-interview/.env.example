DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Gemini on Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=vertex-weare
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_SERVICE_ACCOUNT_JSON_BASE64=your_vertex_service_account_json_base64
GOOGLE_CLOUD_STT_MODEL=latest_short
GOOGLE_CLOUD_STT_LANGUAGE_CODE=ko-KR
GOOGLE_CLOUD_STT_MAX_ALTERNATIVES=3
GEMINI_MODEL=gemini-2.5-flash

# Optional GitHub API token for public repo analysis stability
GITHUB_TOKEN=

CORS_ORIGINS=http://localhost:3000

# Voice pipeline
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
GEMINI_API_KEY=
GEMINI_LIVE_STT_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_LIVE_TTS_MODEL=gemini-2.5-flash-native-audio-latest
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_LIVE_TTS_VOICE=Kore
VOICE_RUNTIME_ARCHITECTURE=hybrid
VOICE_PARALLEL_STT_ENABLED=false

# LiveKit (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# VAD tuning
VOICE_VAD_THRESHOLD=0.017
VOICE_VAD_SPEECH_START_MS=150
VOICE_VAD_SILENCE_MS=560
VOICE_MIN_SPEECH_MS=280
VOICE_VAD_MIN_UTTERANCE_MS=850
VOICE_VAD_SHORT_UTTERANCE_SILENCE_MS=1000
VOICE_TURN_END_GRACE_MS=90
VOICE_MAX_SEGMENT_MS=30000
VOICE_ENABLE_AI_QUESTION_REPAIR=true
VOICE_ENABLE_AI_AUDIO_RECOVERY=true
