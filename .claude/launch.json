{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "ai-interview",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "ai-interview", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "workspace-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "workspace-server", "run", "dev"],
      "port": 4000
    }
  ]
}
