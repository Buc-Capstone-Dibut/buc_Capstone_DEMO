# 서버 포트 설정
# 워크스페이스 서버가 실행될 포트 번호 (기본값: 4000)
PORT=4000

# Next.js BFF URL (화이트보드 저장/로드 API 호출 대상)
# 로컬: http://localhost:3000
# 배포: https://your-app.vercel.app
BFF_URL=http://localhost:3000

# 서버 간 내부 통신 인증 시크릿
# Next.js(Vercel)의 INTERNAL_API_SECRET 값과 반드시 동일해야 함
# 배포 전 긴 랜덤 문자열로 교체 필요 (예: openssl rand -hex 32)
INTERNAL_API_SECRET=your-secret-here
